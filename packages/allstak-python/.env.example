# AllStak Python SDK — environment variables
# Copy to .env and fill in your values

# Required: Raw API key from the AllStak management console
ALLSTAK_API_KEY=ask_live_your_key_here

# Required: AllStak backend URL (no trailing slash)
ALLSTAK_HOST=http://localhost:8080

# Optional: deployment environment
ALLSTAK_ENVIRONMENT=production

# Optional: app version/release tag
ALLSTAK_RELEASE=v1.0.0

# Optional: enable verbose SDK debug logging (any non-empty value)
# ALLSTAK_DEBUG=1
