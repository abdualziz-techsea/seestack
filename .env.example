# SeeStack — Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to git.

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=seestack
POSTGRES_USER=seestack
POSTGRES_PASSWORD=change-me-strong-password

# ── ClickHouse ──────────────────────────────────────────────
CLICKHOUSE_DB=seestack
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=

# ── Keycloak ────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-password
KEYCLOAK_HOSTNAME=localhost

# ── SSH Key Encryption ──────────────────────────────────────
# Must be exactly 32 characters for AES-256
SSH_ENCRYPTION_KEY=change-me-32-char-encryption-key

# ── GitHub Actions Secrets (set in GitHub, not here) ────────
# VPS_HOST=
# VPS_USER=
# VPS_SSH_KEY=
